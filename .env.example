# Server
PORT=3000
NODE_ENV=development

# MongoDB (open MongoDB Compass and copy your connection string here)
MONGO_URI=mongodb://127.0.0.1:27017/fruitablesdb

# Session
SESSION_SECRET=change_this_to_a_long_random_string

# Default admin account created by `npm run seed` (change before deploying!)
ADMIN_EMAIL=admin@fruitables.pk
ADMIN_PASSWORD=admin123

# AI Assistant (optional) - OpenRouter API (https://openrouter.ai)
# Leave blank to run the AI assistant page in "offline / demo" fallback mode
OPENROUTER_API_KEY=OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
SITE_URL=http://localhost:3000
