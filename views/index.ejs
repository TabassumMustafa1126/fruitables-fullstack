</div>
<!-- Featurs Section End -->

<!-- Fruits Shop Start (data comes live from MongoDB) -->
<div class="container-fluid fruite py-5">
    <div class="container py-5">
        <div class="tab-class text-center">
            <h1 class="mb-3 text-primary">Fresh From Our Store</h1>
        </div>
        <ul class="nav nav-pills d-flex justify-content-center mb-4" id="myTab">
            <li class="nav-item"><a class="d-flex m-2 py-2 bg-light rounded-pill text-dark px-4" href="/shop?category=vegetable">Vegetables</a></li>
            <li class="nav-item"><a class="d-flex m-2 py-2 bg-light rounded-pill text-dark px-4" href="/shop?category=fruit">Fruits</a></li>
        </ul>

        <h4 class="mb-3 text-secondary">Vegetables</h4>
        <div class="row g-4">
            <% if (vegetables.length === 0) { %>
                <p class="text-muted">No vegetables in the database yet. Run <code>npm run seed</code>.</p>
            <% } %>
            <% vegetables.forEach(function(item) { %>
                <div class="col-md-6 col-lg-4 col-xl-2 d-flex">
                    <div class="rounded position-relative fruite-item h-100 w-100 d-flex flex-column">
                        <div class="fruite-img"><img src="/img/<%= item.image %>" class="img-fluid w-100 rounded-top" style="height: 160px; object-fit: cover;" alt="<%= item.name %>"></div>
                        <div class="text-white bg-secondary px-3 py-1 rounded position-absolute" style="top: 10px; left: 10px;"><%= item.category %></div>
                        <div class="p-4 border border-secondary border-top-0 rounded-bottom d-flex flex-column flex-grow-1">
                            <a href="/shop/<%= item._id %>" class="text-decoration-none text-dark"><h4><%= item.name %></h4></a>
                            <p><%= item.description.slice(0, 40) %>...</p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between flex-lg-wrap mb-3">
                                    <p class="text-dark fs-5 fw-bold mb-0">Rs <%= item.price.toFixed(0) %> / <%= item.unit %></p>
                                    <form action="/cart/add/<%= item._id %>" method="POST">
                                        <button class="btn border border-secondary rounded-pill px-3 text-primary" type="submit"><i class="fa fa-shopping-bag me-2 text-primary"></i>Add</button>
                                    </form>
                                </div>
                                <a href="/shop/<%= item._id %>" class="btn btn-outline-primary rounded-pill w-100 btn-sm">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <h4 class="mb-3 mt-5 text-secondary">Fruits</h4>
        <div class="row g-4">
            <% if (fruits.length === 0) { %>
                <p class="text-muted">No fruits in the database yet. Run <code>npm run seed</code>.</p>
            <% } %>
            <% fruits.forEach(function(item) { %>
                <div class="col-md-6 col-lg-4 col-xl-2 d-flex">
                    <div class="rounded position-relative fruite-item h-100 w-100 d-flex flex-column">
                        <div class="fruite-img"><img src="/img/<%= item.image %>" class="img-fluid w-100 rounded-top" style="height: 160px; object-fit: cover;" alt="<%= item.name %>"></div>
                        <div class="text-white bg-secondary px-3 py-1 rounded position-absolute" style="top: 10px; left: 10px;"><%= item.category %></div>
                        <div class="p-4 border border-secondary border-top-0 rounded-bottom d-flex flex-column flex-grow-1">
                            <a href="/shop/<%= item._id %>" class="text-decoration-none text-dark"><h4><%= item.name %></h4></a>
                            <p><%= item.description.slice(0, 40) %>...</p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between flex-lg-wrap mb-3">
                                    <p class="text-dark fs-5 fw-bold mb-0">Rs <%= item.price.toFixed(0) %> / <%= item.unit %></p>
                                    <form action="/cart/add/<%= item._id %>" method="POST">
                                        <button class="btn border border-secondary rounded-pill px-3 text-primary" type="submit"><i class="fa fa-shopping-bag me-2 text-primary"></i>Add</button>
                                    </form>
                                </div>
                                <a href="/shop/<%= item._id %>" class="btn btn-outline-primary rounded-pill w-100 btn-sm">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</div>
<!-- Fruits Shop End -->

