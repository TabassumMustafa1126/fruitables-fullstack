<!-- Best Sellers Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="text-center mx-auto mb-5" style="max-width: 700px;">
            <h1 class="mb-3 text-primary">Bestseller Products</h1>
            <p class="text-muted mb-0">Our top-rated fruits and vegetables, ranked by customer reviews.</p>
        </div>

        <% if (bestSellers.length === 0) { %>
            <p class="text-center text-muted">No products yet. Run <code>npm run seed</code> to populate the database.</p>
        <% } %>

        <!-- First 6: circular thumbnail cards -->
        <div class="row g-4">
            <% bestSellers.slice(0, 6).forEach(function(item) { %>
                <div class="col-lg-6 col-xl-4 d-flex">
                    <div class="p-4 rounded bg-light w-100">
                        <div class="row align-items-center h-100">
                            <div class="col-6">
                                <a href="/shop/<%= item._id %>">
                                    <img src="/img/<%= item.image %>" class="img-fluid rounded-circle w-100" style="aspect-ratio: 1 / 1; object-fit: cover;" alt="<%= item.name %>">
                                </a>
                            </div>
                            <div class="col-6 d-flex flex-column">
                                <a href="/shop/<%= item._id %>" class="h5 text-dark text-decoration-none"><%= item.name %></a>
                                <div class="d-flex my-3">
                                    <% for (let s = 0; s < 5; s++) { %>
                                        <i class="fas fa-star <%= s < Math.round(item.rating) ? 'text-primary' : '' %>"></i>
                                    <% } %>
                                </div>
                                <h4 class="mb-3">Rs <%= item.price.toFixed(0) %></h4>
                                <form action="/cart/add/<%= item._id %>" method="POST" class="mt-auto">
                                    <button type="submit" class="btn border border-secondary rounded-pill px-3 text-primary"><i class="fa fa-shopping-bag me-2 text-primary"></i>Add to cart</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Next 4: square thumbnail cards -->
        <div class="row g-4 mt-1">
            <% bestSellers.slice(6, 10).forEach(function(item) { %>
                <div class="col-md-6 col-lg-6 col-xl-3 d-flex">
                    <div class="text-center w-100 d-flex flex-column">
                        <a href="/shop/<%= item._id %>">
                            <img src="/img/<%= item.image %>" class="img-fluid rounded" style="width: 100%; height: 220px; object-fit: cover;" alt="<%= item.name %>">
                        </a>
                        <div class="py-4 d-flex flex-column flex-grow-1">
                            <a href="/shop/<%= item._id %>" class="h5 text-dark text-decoration-none"><%= item.name %></a>
                            <div class="d-flex my-3 justify-content-center">
                                <% for (let s = 0; s < 5; s++) { %>
                                    <i class="fas fa-star <%= s < Math.round(item.rating) ? 'text-primary' : '' %>"></i>
                                <% } %>
                            </div>
                            <h4 class="mb-3">Rs <%= item.price.toFixed(0) %></h4>
                            <form action="/cart/add/<%= item._id %>" method="POST" class="mt-auto">
                                <button type="submit" class="btn border border-secondary rounded-pill px-3 text-primary"><i class="fa fa-shopping-bag me-2 text-primary"></i>Add to cart</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</div>
<!-- Best Sellers End -->

<!-- Fact/Counters Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="bg-light p-5 rounded">
            <div class="row g-4 justify-content-center">
                <div class="col-md-6 col-lg-6 col-xl-3">
                    <div class="text-center bg-white rounded p-5">
                        <i class="fa fa-users text-secondary fa-2x mb-3"></i>
                        <h4>Satisfied Customers</h4>
                        <h1 class="mb-0">1963</h1>
                    </div>
                </div>
                <div class="col-md-6 col-lg-6 col-xl-3">
                    <div class="text-center bg-white rounded p-5">
                        <i class="fa fa-thumbs-up text-secondary fa-2x mb-3"></i>
                        <h4>Quality of Service</h4>
                        <h1 class="mb-0">99%</h1>
                    </div>
                </div>
                <div class="col-md-6 col-lg-6 col-xl-3">
                    <div class="text-center bg-white rounded p-5">
                        <i class="fa fa-certificate text-secondary fa-2x mb-3"></i>
                        <h4>Quality Certificates</h4>
                        <h1 class="mb-0">33</h1>
                    </div>
                </div>
                <div class="col-md-6 col-lg-6 col-xl-3">
                    <div class="text-center bg-white rounded p-5">
                        <i class="fa fa-carrot text-secondary fa-2x mb-3"></i>
                        <h4>Available Products</h4>
                        <h1 class="mb-0"><%= productCount %></h1>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Fact/Counters End -->

<!-- Testimonial Preview Start -->
<div class="container-fluid testimonial py-5">
    <div class="container py-5">
        <div class="testimonial-header text-center">
            <h4 class="text-primary">Our Testimonial</h4>
            <h1 class="display-5 mb-5 text-dark">Our Client Saying!</h1>
        </div>
        <% if (testimonials.length === 0) { %>
            <p class="text-center text-muted">No testimonials yet. Run <code>npm run seed</code> or add some from the admin panel.</p>
        <% } %>
        <div class="owl-carousel testimonial-carousel">
            <% testimonials.forEach(function(t) { %>
                <div class="testimonial-item img-border-radius bg-light rounded p-4">
                    <div class="position-relative">
                        <i class="fa fa-quote-right fa-2x text-secondary position-absolute" style="bottom: 30px; right: 0;"></i>
                        <div class="mb-4 pb-4 border-bottom border-secondary">
                            <p class="mb-0"><%= t.message %></p>
                        </div>
                        <div class="d-flex align-items-center flex-nowrap">
                            <div class="bg-secondary rounded">
                                <img src="/img/<%= t.photo %>" class="img-fluid rounded" style="width: 100px; height: 100px; object-fit: cover;" alt="<%= t.name %>">
                            </div>
                            <div class="ms-4 d-block">
                                <h4 class="text-dark"><%= t.name %></h4>
                                <p class="m-0 pb-3"><%= t.profession %></p>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="text-center mt-4">
            <a href="/testimonial" class="btn btn-primary rounded-pill px-4 py-2">See All Testimonials</a>
        </div>
    </div>
</div>
<!-- Testimonial Preview End -->

<!-- Latest From Blog Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="text-center mx-auto mb-5" style="max-width: 600px;">
            <h4 class="text-secondary">Our Blog</h4>
            <h1 class="mb-3 text-primary">Latest From The Blog</h1>
        </div>
        <% if (latestPosts.length === 0) { %>
            <p class="text-center text-muted">No blog posts yet. Add some from the admin panel at <code>/admin/blog</code>.</p>
        <% } %>
        <div class="row g-4">
            <% latestPosts.forEach(function(post) { %>
                <div class="col-md-6 col-lg-4 d-flex">
                    <div class="rounded border h-100 w-100 overflow-hidden d-flex flex-column">
                        <img src="/img/<%= post.image %>" class="img-fluid w-100" style="height: 180px; object-fit: cover;" alt="<%= post.title %>">
                        <div class="p-4 d-flex flex-column flex-grow-1">
                            <small class="text-muted"><%= post.author %></small>
                            <h5 class="mt-2"><%= post.title %></h5>
                            <p class="text-muted"><%= post.excerpt.slice(0, 60) %>...</p>
                            <a href="/blog/<%= post._id %>" class="btn btn-outline-primary rounded-pill px-4 mt-auto align-self-start">Read More</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</div>
<!-- Latest From Blog End -->
