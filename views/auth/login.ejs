<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6">Login</h1>
</div>

<div class="container-fluid py-5">
    <div class="container" style="max-width: 450px;">
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="row g-3">
            <div class="col-12">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" value="<%= formData.email || '' %>" required>
            </div>
            <div class="col-12">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" required>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary rounded-pill w-100 py-2">Login</button>
            </div>
        </form>

        <p class="text-center mt-4 mb-0">
            Don't have an account? <a href="/register">Register here</a>
        </p>
    </div>
</div>
