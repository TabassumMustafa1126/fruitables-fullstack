<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6"><%= coupon && coupon._id ? 'Edit Coupon' : 'Add New Coupon' %></h1>
</div>

<div class="container-fluid py-4">
    <div class="container" style="max-width: 700px;">
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <ul class="mb-0"><% errors.forEach(function(msg) { %><li><%= msg %></li><% }); %></ul>
            </div>
        <% } %>

        <%
            // input[type=date] needs yyyy-mm-dd - reduce whatever we were handed to that.
            let expiryValue = '';
            if (coupon && coupon.expiryDate) {
                const d = new Date(coupon.expiryDate);
                if (!isNaN(d)) expiryValue = d.toISOString().slice(0, 10);
            }
        %>

        <form
            action="<%= coupon && coupon._id ? '/admin/coupons/' + coupon._id + '?_method=PUT' : '/admin/coupons' %>"
            method="POST"
            class="row g-3"
        >
            <div class="col-md-6">
                <label class="form-label">Coupon Code</label>
                <input type="text" name="code" class="form-control text-uppercase" value="<%= coupon ? coupon.code : '' %>" placeholder="e.g. SAVE20" required>
            </div>
            <div class="col-md-6">
                <label class="form-label">Discount Type</label>
                <select name="discountType" class="form-select" required>
                    <option value="percentage" <%= !coupon || coupon.discountType === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
                    <option value="fixed" <%= coupon && coupon.discountType === 'fixed' ? 'selected' : '' %>>Fixed Amount (Rs)</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Discount Value</label>
                <input type="number" step="0.01" min="0" name="discountValue" class="form-control" value="<%= coupon ? coupon.discountValue : '' %>" required>
                <small class="text-muted">% if type is Percentage, Rs if type is Fixed.</small>
            </div>
            <div class="col-md-4">
                <label class="form-label">Max Discount (Rs, optional)</label>
                <input type="number" step="0.01" min="0" name="maxDiscount" class="form-control" value="<%= coupon && coupon.maxDiscount ? coupon.maxDiscount : '' %>">
                <small class="text-muted">Caps a percentage discount. Ignored for Fixed.</small>
            </div>
            <div class="col-md-4">
                <label class="form-label">Min Purchase (Rs, optional)</label>
                <input type="number" step="0.01" min="0" name="minPurchase" class="form-control" value="<%= coupon && coupon.minPurchase ? coupon.minPurchase : '' %>">
            </div>
            <div class="col-md-6">
                <label class="form-label">Expiry Date (optional)</label>
                <input type="date" name="expiryDate" class="form-control" value="<%= expiryValue %>">
            </div>
            <div class="col-md-6">
                <label class="form-label">Usage Limit (optional)</label>
                <input type="number" min="0" name="usageLimit" class="form-control" value="<%= coupon && coupon.usageLimit ? coupon.usageLimit : '' %>" placeholder="Leave blank for unlimited">
            </div>
            <div class="col-12 form-check ps-4">
                <input type="checkbox" name="isActive" class="form-check-input" id="isActive" <%= !coupon || coupon.isActive ? 'checked' : '' %>>
                <label class="form-check-label" for="isActive">Active</label>
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-4"><%= coupon && coupon._id ? 'Save Changes' : 'Create Coupon' %></button>
                <a href="/admin/coupons" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>
