<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6">Admin - Manage Products</h1>
</div>

<div class="container-fluid py-4">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">All Products (<%= products.length %>)</h4>
            <a href="/admin/products/new" class="btn btn-primary rounded-pill px-4"><i class="fa fa-plus me-2"></i>Add New Product</a>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products.length === 0) { %>
                        <tr><td colspan="6" class="text-center text-muted py-4">No products yet. Click "Add New Product" to create one.</td></tr>
                    <% } %>
                    <% products.forEach(function(p) { %>
                        <tr>
                            <td><img src="/img/<%= p.image %>" style="width:50px;height:50px;object-fit:cover;" class="rounded" alt="<%= p.name %>"></td>
                            <td><%= p.name %></td>
                            <td><%= p.category %></td>
                            <td>Rs <%= p.price.toFixed(0) %> / <%= p.unit %></td>
                            <td><%= p.stock %></td>
                            <td>
                                <a href="/admin/products/<%= p._id %>/edit" class="btn btn-sm btn-outline-secondary me-1"><i class="fa fa-pen"></i></a>
                                <form action="/admin/products/<%= p._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>
