<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6">Admin - Manage Coupons</h1>
</div>

<div class="container-fluid py-4">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">All Coupons (<%= coupons.length %>)</h4>
            <a href="/admin/coupons/new" class="btn btn-primary rounded-pill px-4"><i class="fa fa-plus me-2"></i>Add New Coupon</a>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Discount</th>
                        <th>Min Purchase</th>
                        <th>Expiry</th>
                        <th>Usage</th>
                        <th>Status</th>
                        <th style="width: 160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (coupons.length === 0) { %>
                        <tr><td colspan="7" class="text-center text-muted py-4">No coupons yet. Click "Add New Coupon" to create one.</td></tr>
                    <% } %>
                    <% coupons.forEach(function(c) { %>
                        <% const expired = c.expiryDate && new Date(c.expiryDate) < new Date(); %>
                        <% const usedUp = c.usageLimit && c.usedCount >= c.usageLimit; %>
                        <tr>
                            <td><code><%= c.code %></code></td>
                            <td><%= c.discountType === 'percentage' ? c.discountValue + '%' : 'Rs ' + c.discountValue %><% if (c.discountType === 'percentage' && c.maxDiscount) { %> <small class="text-muted">(max Rs <%= c.maxDiscount %>)</small><% } %></td>
                            <td><%= c.minPurchase ? 'Rs ' + c.minPurchase : '-' %></td>
                            <td><%= c.expiryDate ? new Date(c.expiryDate).toDateString() : 'No expiry' %></td>
                            <td><%= c.usedCount %><%= c.usageLimit ? ' / ' + c.usageLimit : '' %></td>
                            <td>
                                <% if (!c.isActive) { %>
                                    <span class="badge bg-secondary">Disabled</span>
                                <% } else if (expired) { %>
                                    <span class="badge bg-danger">Expired</span>
                                <% } else if (usedUp) { %>
                                    <span class="badge bg-danger">Limit reached</span>
                                <% } else { %>
                                    <span class="badge bg-success">Active</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/admin/coupons/<%= c._id %>/edit" class="btn btn-sm btn-outline-secondary me-1"><i class="fa fa-pen"></i></a>
                                <form action="/admin/coupons/<%= c._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Delete this coupon?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>
