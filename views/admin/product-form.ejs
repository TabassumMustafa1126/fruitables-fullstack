<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6"><%= product && product._id ? 'Edit Product' : 'Add New Product' %></h1>
</div>

<div class="container-fluid py-4">
    <div class="container" style="max-width: 700px;">
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <ul class="mb-0"><% errors.forEach(function(msg) { %><li><%= msg %></li><% }); %></ul>
            </div>
        <% } %>

        <form
            action="<%= product && product._id ? '/admin/products/' + product._id + '?_method=PUT' : '/admin/products' %>"
            method="POST"
            class="row g-3"
        >
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required>
            </div>
            <div class="col-md-6">
                <label class="form-label">Category</label>
                <select name="category" class="form-select" required>
                    <option value="vegetable" <%= product && product.category === 'vegetable' ? 'selected' : '' %>>Vegetable</option>
                    <option value="fruit" <%= product && product.category === 'fruit' ? 'selected' : '' %>>Fruit</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Price (Rs)</label>
                <input type="number" step="0.01" name="price" class="form-control" value="<%= product ? product.price : '' %>" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Old Price (optional)</label>
                <input type="number" step="0.01" name="oldPrice" class="form-control" value="<%= product && product.oldPrice ? product.oldPrice : '' %>">
            </div>
            <div class="col-md-4">
                <label class="form-label">Unit</label>
                <input type="text" name="unit" class="form-control" value="<%= product ? product.unit : 'kg' %>" placeholder="kg, dozen, box, piece...">
            </div>
            <div class="col-md-6">
                <label class="form-label">Image filename</label>
                <input type="text" name="image" class="form-control" value="<%= product ? product.image : '' %>" placeholder="e.g. fruite-item-1.jpg" required>
                <small class="text-muted">File must already exist in <code>public/img/</code>.</small>
            </div>
            <div class="col-md-3">
                <label class="form-label">Rating (0-5)</label>
                <input type="number" min="0" max="5" name="rating" class="form-control" value="<%= product ? product.rating : 4 %>">
            </div>
            <div class="col-md-3">
                <label class="form-label">Stock</label>
                <input type="number" min="0" name="stock" class="form-control" value="<%= product ? product.stock : 50 %>">
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3"><%= product ? product.description : '' %></textarea>
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-4"><%= product && product._id ? 'Save Changes' : 'Create Product' %></button>
                <a href="/admin/products" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>
