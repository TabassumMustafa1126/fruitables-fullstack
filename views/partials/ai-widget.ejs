<!-- Floating AI Chat Widget: shows on every page, no separate /ai page needed -->
<style>
    #ai-widget-toggle {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: #111112;
        color: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
        z-index: 1050;
        cursor: pointer;
    }
    #ai-widget-toggle:hover { background: #2b2b2d; }

    #ai-widget-panel {
        position: fixed;
        bottom: 92px;
        right: 24px;
        width: 340px;
        max-width: calc(100vw - 32px);
        height: 460px;
        max-height: calc(100vh - 140px);
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
        display: none;
        flex-direction: column;
        overflow: hidden;
        z-index: 1050;
    }
    #ai-widget-panel.open { display: flex; }

    #ai-widget-header {
        background: #111112;
        color: #fff;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 14px;
        font-weight: 600;
    }
    #ai-widget-close { background: none; border: none; color: #fff; font-size: 16px; cursor: pointer; }

    #ai-widget-log {
        flex: 1;
        overflow-y: auto;
        padding: 14px;
        background: #fafafa;
        font-size: 13.5px;
    }
    .ai-msg-row { display: flex; flex-direction: column; margin-bottom: 12px; }
    .ai-msg-row.user { align-items: flex-end; }
    .ai-msg-row.assistant { align-items: flex-start; }
    .ai-msg-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #9a9a9a; margin-bottom: 2px; }
    .ai-msg-bubble {
        max-width: 85%;
        padding: 8px 12px;
        border-radius: 8px;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .ai-msg-row.user .ai-msg-bubble { background: #111112; color: #fff; }
    .ai-msg-row.assistant .ai-msg-bubble { background: #fff; border: 1px solid #e5e5e5; color: #222; }

    #ai-widget-form {
        display: flex;
        gap: 6px;
        padding: 10px;
        border-top: 1px solid #eee;
        background: #fff;
    }
    #ai-widget-input {
        flex: 1;
        border: 1px solid #ddd;
        border-radius: 20px;
        padding: 8px 14px;
        font-size: 13px;
        outline: none;
    }
    #ai-widget-send {
        background: #111112;
        color: #fff;
        border: none;
        border-radius: 20px;
        padding: 8px 16px;
        font-size: 13px;
        cursor: pointer;
    }
    #ai-widget-send:disabled { opacity: 0.6; cursor: not-allowed; }
    #ai-widget-note { font-size: 10px; color: #b8860b; padding: 4px 12px 0; }
</style>

<button id="ai-widget-toggle" title="Chat with AI"><i class="fa fa-comment-dots"></i></button>

<div id="ai-widget-panel">
    <div id="ai-widget-header">
        <span>AI Assistant</span>
        <button id="ai-widget-close" type="button">&times;</button>
    </div>
    <div id="ai-widget-log"></div>
    <div id="ai-widget-note" style="display:none;">Demo mode: add OPENROUTER_API_KEY in .env for real replies.</div>
    <form id="ai-widget-form">
        <input type="text" id="ai-widget-input" placeholder="Ask me anything..." autocomplete="off" required>
        <button id="ai-widget-send" type="submit">Send</button>
    </form>
</div>

<script>
(function () {
    const toggleBtn = document.getElementById('ai-widget-toggle');
    const closeBtn = document.getElementById('ai-widget-close');
    const panel = document.getElementById('ai-widget-panel');
    const log = document.getElementById('ai-widget-log');
    const note = document.getElementById('ai-widget-note');
    const form = document.getElementById('ai-widget-form');
    const input = document.getElementById('ai-widget-input');
    const sendBtn = document.getElementById('ai-widget-send');

    let historyLoaded = false;

    function renderMessage(role, text) {
        const row = document.createElement('div');
        row.className = 'ai-msg-row ' + role;

        const label = document.createElement('div');
        label.className = 'ai-msg-label';
        label.textContent = role === 'user' ? 'You' : 'Assistant';

        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        bubble.textContent = text;

        row.appendChild(label);
        row.appendChild(bubble);
        log.appendChild(row);
        log.scrollTop = log.scrollHeight;
    }

    async function loadHistory() {
        try {
            const res = await fetch('/ai/history');
            const data = await res.json();
            log.innerHTML = '';
            (data.messages || []).forEach((m) => renderMessage(m.role, m.text));
            note.style.display = data.aiConfigured ? 'none' : 'block';
            historyLoaded = true;
        } catch (err) {
            renderMessage('assistant', 'Could not load chat history.');
        }
    }

    toggleBtn.addEventListener('click', () => {
        panel.classList.toggle('open');
        if (panel.classList.contains('open') && !historyLoaded) {
            loadHistory();
        }
    });

    closeBtn.addEventListener('click', () => panel.classList.remove('open'));

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const message = input.value.trim();
        if (!message) return;

        renderMessage('user', message);
        input.value = '';
        sendBtn.disabled = true;
        sendBtn.textContent = '...';

        try {
            const res = await fetch('/ai/ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userPrompt: message }),
            });
            const data = await res.json();
            renderMessage('assistant', data.reply || data.error || 'Something went wrong.');
        } catch (err) {
            renderMessage('assistant', 'Network error - please try again.');
        } finally {
            sendBtn.disabled = false;
            sendBtn.textContent = 'Send';
        }
    });
})();
</script>
