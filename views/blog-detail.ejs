<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6"><%= post.title %></h1>
</div>

<div class="container-fluid py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-8">
                <img src="/img/<%= post.image %>" class="img-fluid w-100 rounded mb-4" style="max-height: 400px; object-fit: cover;" alt="<%= post.title %>">
                <small class="text-muted">By <%= post.author %> &middot; <%= post.createdAt.toDateString() %></small>
                <div class="mt-3" style="white-space: pre-wrap; line-height: 1.8;"><%= post.content %></div>
                <a href="/blog" class="btn btn-outline-secondary rounded-pill px-4 mt-4">&larr; Back to Blog</a>
            </div>
            <div class="col-lg-4">
                <h5 class="mb-3">Recent Posts</h5>
                <% recentPosts.forEach(function(p) { %>
                    <a href="/blog/<%= p._id %>" class="d-flex align-items-center gap-3 mb-3 text-decoration-none text-dark">
                        <img src="/img/<%= p.image %>" style="width:60px;height:60px;object-fit:cover;" class="rounded" alt="<%= p.title %>">
                        <span><%= p.title %></span>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>
</div>
