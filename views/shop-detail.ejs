<!-- Page Header Start -->
<div class="container-fluid page-header py-5 mb-5">
    <h1 class="text-center text-white display-6"><%= product.name %></h1>
</div>
<!-- Page Header End -->

<div class="container-fluid py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Main product column -->
            <div class="col-lg-8">
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <img src="/img/<%= product.image %>" class="img-fluid rounded w-100" alt="<%= product.name %>">
                    </div>
                    <div class="col-md-6">
                        <h2><%= product.name %></h2>
                        <p class="text-muted mb-2 text-capitalize">Category: <%= product.category %></p>
                        <h3 class="text-primary mb-2">
                            Rs <%= product.price.toFixed(0) %>
                            <% if (product.oldPrice) { %><small class="text-muted text-decoration-line-through">Rs <%= product.oldPrice.toFixed(0) %></small><% } %>
                        </h3>
                        <div class="d-flex mb-3">
                            <% for (let s = 0; s < 5; s++) { %>
                                <i class="fa fa-star <%= s < Math.round(avgRating) ? 'text-secondary' : 'text-black-50' %>"></i>
                            <% } %>
                            <span class="text-muted ms-2">(<%= reviews.length %> review<%= reviews.length === 1 ? '' : 's' %>)</span>
                        </div>
                        <p><%= product.description %></p>
                        <p class="text-muted">In stock: <%= product.stock %> <%= product.unit %></p>

                        <form action="/cart/add/<%= product._id %>" method="POST" class="d-flex align-items-center gap-3 mt-4">
                            <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>" class="form-control" style="width: 100px;">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 py-2">
                                <i class="fa fa-shopping-bag me-2"></i>Add To Cart
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Description / Reviews Tabs -->
                <ul class="nav nav-tabs mb-4" id="productTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="description-tab" data-bs-toggle="tab" data-bs-target="#description-pane" type="button" role="tab">Description</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-pane" type="button" role="tab">Reviews (<%= reviews.length %>)</button>
                    </li>
                </ul>

                <div class="tab-content" id="productTabContent">
                    <!-- Description Pane -->
                    <div class="tab-pane fade show active" id="description-pane" role="tabpanel">
                        <p><%= product.description %></p>
                        <table class="table table-striped mt-3">
                            <tbody>
                                <tr><th style="width: 200px;">Weight</th><td>1 <%= product.unit %></td></tr>
                                <tr><th>Country of Origin</th><td><%= product.origin %></td></tr>
                                <tr><th>Quality</th><td><%= product.quality %></td></tr>
                                <tr><th>Check</th><td>Healthy</td></tr>
                                <tr><th>Min Order Weight</th><td><%= product.minOrderWeight %> <%= product.unit %></td></tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Reviews Pane -->
                    <div class="tab-pane fade" id="reviews-pane" role="tabpanel">
                        <div id="reviews">
                            <% if (reviews.length === 0) { %>
                                <p class="text-muted">No reviews yet. Be the first to review this product!</p>
                            <% } %>
                            <% reviews.forEach(function(r) { %>
                                <div class="border-bottom pb-3 mb-3">
                                    <div class="d-flex justify-content-between">
                                        <strong><%= r.name %></strong>
                                        <small class="text-muted"><%= r.createdAt.toDateString() %></small>
                                    </div>
                                    <div class="mb-1">
                                        <% for (let s = 0; s < 5; s++) { %>
                                            <i class="fa fa-star <%= s < r.rating ? 'text-secondary' : 'text-black-50' %>"></i>
                                        <% } %>
                                    </div>
                                    <p class="mb-0"><%= r.comment %></p>
                                </div>
                            <% }); %>
                        </div>

                        <h5 class="mt-4 mb-3">Leave a Reply</h5>
                        <form action="/shop/<%= product._id %>/reviews" method="POST" class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" name="name" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Rating</label>
                                <select name="rating" class="form-select" required>
                                    <option value="5">5 - Excellent</option>
                                    <option value="4" selected>4 - Good</option>
                                    <option value="3">3 - Average</option>
                                    <option value="2">2 - Below Average</option>
                                    <option value="1">1 - Poor</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Comment</label>
                                <textarea name="comment" class="form-control" rows="3" required></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary rounded-pill px-4">Submit Review</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <form action="/shop" method="GET" class="position-relative mb-4">
                    <input type="text" name="search" class="form-control py-3 px-4" placeholder="keywords">
                    <button type="submit" class="btn btn-primary position-absolute" style="top: 0; right: 0; height: 100%;"><i class="fa fa-search"></i></button>
                </form>

                <h5 class="mb-3">Categories</h5>
                <ul class="list-unstyled mb-5">
                    <li class="d-flex justify-content-between border-bottom py-2">
                        <a href="/shop?category=fruit" class="text-decoration-none text-dark"><i class="fa fa-apple-alt text-primary me-2"></i>Fruits</a>
                        <span class="text-muted">(<%= categoryCounts.fruit %>)</span>
                    </li>
                    <li class="d-flex justify-content-between border-bottom py-2">
                        <a href="/shop?category=vegetable" class="text-decoration-none text-dark"><i class="fa fa-carrot text-primary me-2"></i>Vegetables</a>
                        <span class="text-muted">(<%= categoryCounts.vegetable %>)</span>
                    </li>
                </ul>

                <h5 class="mb-3">Featured Products</h5>
                <% featuredProducts.forEach(function(fp) { %>
                    <a href="/shop/<%= fp._id %>" class="d-flex align-items-center gap-3 mb-3 text-decoration-none text-dark">
                        <img src="/img/<%= fp.image %>" style="width:60px;height:60px;object-fit:cover;" class="rounded" alt="<%= fp.name %>">
                        <div>
                            <p class="mb-1"><%= fp.name %></p>
                            <div class="mb-1">
                                <% for (let s = 0; s < 5; s++) { %>
                                    <i class="fa fa-star fa-xs <%= s < Math.round(fp.rating) ? 'text-secondary' : 'text-black-50' %>"></i>
                                <% } %>
                            </div>
                            <p class="mb-0 fw-bold">Rs <%= fp.price.toFixed(0) %></p>
                        </div>
                    </a>
                <% }); %>
            </div>
        </div>

        <!-- Related Products -->
        <% if (relatedProducts.length > 0) { %>
            <h3 class="mt-5 mb-4">Related Products</h3>
            <div class="row g-4">
                <% relatedProducts.forEach(function(item) { %>
                    <div class="col-md-6 col-lg-3 d-flex">
                        <div class="rounded position-relative fruite-item h-100 w-100 d-flex flex-column">
                            <div class="fruite-img"><img src="/img/<%= item.image %>" class="img-fluid w-100 rounded-top" style="height: 160px; object-fit: cover;" alt="<%= item.name %>"></div>
                            <div class="text-white bg-secondary px-3 py-1 rounded position-absolute text-capitalize" style="top: 10px; left: 10px;"><%= item.category %></div>
                            <div class="p-4 border border-secondary border-top-0 rounded-bottom d-flex flex-column flex-grow-1">
                                <a href="/shop/<%= item._id %>" class="text-decoration-none text-dark"><h5><%= item.name %></h5></a>
                                <p><%= item.description.slice(0, 50) %>...</p>
                                <div class="d-flex justify-content-between flex-lg-wrap mt-auto">
                                    <p class="text-dark fs-5 fw-bold mb-0">Rs <%= item.price.toFixed(0) %> / <%= item.unit %></p>
                                    <form action="/cart/add/<%= item._id %>" method="POST">
                                        <button class="btn border border-secondary rounded-pill px-3 text-primary" type="submit"><i class="fa fa-shopping-bag me-2 text-primary"></i>Add</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</div>
